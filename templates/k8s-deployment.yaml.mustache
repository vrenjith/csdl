apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{name}}-deployment
spec:
  replicas: {{replicas}}
  selector:
    matchLabels:
      app: {{name}}
  template:
    metadata:
      labels:
        app: {{name}}
    spec:
      containers:
        - name: {{name}}
          image: {{image}}
          ports:
          {{#ports}}
            - containerPort: {{.}}
          {{/ports}}
          env:
          {{#env}}
            - name: {{name}}
              value: "{{value}}"
          {{/env}}
          resources:
            requests:
              cpu: "{{resources.requests.cpu}}"
              memory: "{{resources.requests.memory}}"
            limits:
              cpu: "{{resources.limits.cpu}}"
              memory: "{{resources.limits.memory}}"
---
apiVersion: v1
kind: Service
metadata:
  name: {{name}}-svc
spec:
  selector:
    app: {{name}}
  ports:
  {{#ports}}
    - port: {{.}}
      targetPort: {{.}}
  {{/ports}}
  type: ClusterIP
