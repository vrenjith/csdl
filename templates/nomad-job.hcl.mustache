job "{{name}}" {
  datacenters = ["dc1"]
  type = "service"

  group "{{name}}-group" {
    count = {{replicas}}

    task "{{name}}" {
      driver = "docker"

      config {
        image = "{{image}}"
        port_map = [{ http = {{ports.0}} }]
      }

      resources {
        cpu    = {{resources.requests.cpu}}
        memory = {{resources.requests.memory}}
      }

      env = {
      {{#env}}
        {{name}} = "{{value}}"
      {{/env}}
      }

      service {
        name = "{{name}}"
        port = "http"
      }
    }

    network {
      port "http" {
        static = {{ports.0}}
      }
    }
  }
}
